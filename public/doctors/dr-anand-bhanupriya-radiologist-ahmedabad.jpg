      section.privacypolicy.errorsection {
    float: left;
    width: 100%;
    padding: 150px 100px 100px;
}

.errorquickwrap{ float: left;
    width: 100%;}
   .errorsection h2 {
    color: #007dc6;
    font-size: 40px;
}
.errorsection h4 {    margin-bottom: 30px;
    color: #000;}
.errorsection a {
    padding: 10px 20px;
    color: #fff;
    background-color: #FF6F0F;
}
.errorsection{position: relative;}
.errorsection::before {
    content: "";
    background: url(../static/web/img/logoIcon2.png);
    position: absolute;
    top: 150px;
    width: 409px;
    height: 564px;
    background-repeat: no-repeat;
    right: 0;    z-index: -1;
}
@media (max-width: 1024px) {
  section.privacypolicy.errorsection {
    float: left;
    width: 100%;
    padding: 130px 20px 50px;
}
.errorsection h2 {
    color: #007dc6;
    font-size: 37px;
}
.errorquickwrap {
    float: left;
    width: 100%;
    margin-bottom: 50px;
}
}

@media (max-width: 450px) {
  .errorsection h2 {
    color: #007dc6;
    font-size: 29px;
}
  section.privacypolicy.errorsection {
    float: left;
    width: 100%;
    padding: 100px 20px 50px;
}

}
